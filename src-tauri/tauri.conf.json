{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "cute-sticky",
  "version": "0.2.0",
  "identifier": "com.cute.sticky",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "cute-sticky",
        "width": 360,
        "height": 480,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM3NUQyMDQwNkM4MzI1RUIKUldUckpZTnNRQ0JkTjVzbEpYVDVWRmt4N25za0l4NjRxQ3dDRTlWOEhSR3lzZ2RZNEpGZUtYa1YK",
      "endpoints": [
        "https://github.com/Aley3567/cutesticky/releases/latest/download/latest.json"
      ]
    }
  }
}
